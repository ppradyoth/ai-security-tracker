    "security_references": [
      {
        "name": "OWASP Top 10",
        "owner": "OWASP",
        "repo": "Top10",
        "focus": "Web application security"
      },
      {
        "name": "Awesome Security",
        "owner": "sbilly",
        "repo": "awesome-security",
        "focus": "Curated list of security resources"
      }
    ]
  },

  "security_signals": {
    "security_labels": [
      "security",
      "vulnerability",
      "cve",
      "critical",
      "high",
      "security-issue",
      "bug"
    ],

    "credential_keywords": [
      "credential",
      "secret",
      "api_key",
      "apikey",
      "password",
      "token",
      "bearer",
      "authentication",
      "oauth",
      "jwt",
      "private_key",
      "API key"
    ],

    "vulnerability_keywords": [
      "vulnerability",
      "vuln",
      "exploit",
      "attack",
      "injection",
      "xss",
      "csrf",
      "sql injection",
      "remote code execution",
      "rce",
      "privilege escalation",
      "dos",
      "denial of service"
    ],

    "security_initiative_keywords": [
      "security fix",
      "security enhancement",
      "security improvement",
      "hardened",
      "secure",
      "encryption",
      "secure by default",
      "threat model"
    ]
  },

  "data_collection": {
    "time_window_days": 180,
    "update_frequency": "daily",
    "sources": ["github_api"]
  },

  "report_schedule": {
    "daily": {
      "time": "08:00 UTC",
      "description": "Daily snapshot of new security issues/PRs"
    },
    "weekly": {
      "day": "Monday",
      "time": "09:00 UTC",
      "description": "Weekly trend analysis"
    },
    "monthly": {
      "day": "1",
      "time": "10:00 UTC",
      "description": "Monthly deep dive"
    }
  },

  "notes": "Phase 1 MVP: Focus on GitHub API data collection across 30+ curated repos. Phase 2 will add trend analysis, CVE data, and advanced dashboards."
}
